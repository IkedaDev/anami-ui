---
// docs/src/components/Showcase.astro
import { Code } from '@astrojs/starlight/components'; // Importamos el componente de código de Starlight

const { htmlCode } = Astro.props;
---
<div class="an-showcase-container">
  <div class="an-showcase-wrapper">
    <div class="an-scaling-container">
      <Fragment set:html={htmlCode} />
    </div>
  </div>

  <div class="an-code-output">
    <Code code={htmlCode} lang="html" title="Estructura HTML" />
  </div>
</div>

<style>
  .an-showcase-container {
    margin: 2rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .an-showcase-wrapper {
    border: 1px solid var(--sl-color-gray-5);
    background: #fff;
    border-radius: 8px 8px 0 0; /* Bordes redondeados solo arriba */
    padding: 3rem 2rem;
    overflow: hidden;
    display: flex;
    justify-content: center;
  }

  .an-scaling-container {
    transform: scale(0.625);
    transform-origin: center center;
    width: 160%; 
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
  }

  /* Ajuste para que el bloque de código se pegue a la vista previa */
  .an-code-output :global(pre) {
    margin-top: 0 !important;
    border-top: none !important;
    border-radius: 0 0 8px 8px !important;
  }
</style>