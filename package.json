{
  "name": "@ikedadev/anami-ui",
  "version": "1.3.1",
  "description": "Anami UI Design System - Core SCSS & Components",
  "main": "dist/anami.css",
  "style": "dist/anami.css",
  "sass": "scss/main.scss",
  "files": [
    "dist",
    "scss"
  ],
  "scripts": {
    "build": "sass scss/main.scss dist/anami.css --style compressed",
    "start": "npx vite",
    "watch": "sass scss/main.scss dist/anami.css --watch",
    "publish": "npm login && npm publish --access public"
  },
  "keywords": [
    "anami",
    "design-system",
    "scss",
    "ui-library"
  ],
  "author": "IkedaDev",
  "license": "MIT",
  "devDependencies": {
    "sass": "^1.71.0",
    "vite": "^5.1.0"
  }
}
